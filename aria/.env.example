# ── Aria Voice Receptionist — Environment Configuration ───────────────────────
# Copy this file: cp .env.example aria/.env
# Fill in your credentials (most are optional — system runs in mock mode)

# ── LLM APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here          # Free at groq.com

# ── Bolna AI (Voice Agent Platform) ─────────────────────────────────────────
BOLNA_API_KEY=your_bolna_api_key
BOLNA_AGENT_ID=your_bolna_agent_id

# ── Redis (Session State) ────────────────────────────────────────────────────
# Option A: Upstash (FREE — https://upstash.com, region ap-south-1)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Option B: Local Redis (via Docker or WSL)
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL=3600                    # Session TTL in seconds (1 hour)

# ── Database (Durable Storage) ──────────────────────────────────────────────
# Option A: Supabase PostgreSQL (FREE — https://supabase.com)
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Option B: Local PostgreSQL (via Docker)
# DATABASE_URL=postgresql://aria:ariapass123@localhost:5432/aria_db

# Option C: SQLite (zero setup — great for development)
DATABASE_URL=sqlite:///./aria_calls.db

# ── Google Calendar ──────────────────────────────────────────────────────────
# Setup: console.cloud.google.com → Enable Calendar API → OAuth credentials
# Download JSON → save as: aria/integrations/credentials.json
GOOGLE_CALENDAR_ID=primary                # Use 'primary' for main calendar

# Clinic hours
CLINIC_TIMEZONE=Asia/Kolkata
CLINIC_START_HOUR=9                       # 9 AM
CLINIC_END_HOUR=18                        # 6 PM
SLOT_DURATION_MINS=30                     # 30-minute appointments

# ── Twilio (WhatsApp + SMS) ──────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX          # Your Twilio number

# ── Clinic Information ───────────────────────────────────────────────────────
CLINIC_NAME=Naveen Advanced Dental Clinic
CLINIC_PHONE=+91-XXXXXXXXXX
CLINIC_ADDRESS=123 Dental Street, Hyderabad, Telangana 500001

# ── API Configuration ────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development                   # development | production
LOG_LEVEL=info

# ── Docker Postgres (docker-compose only) ────────────────────────────────────
POSTGRES_USER=aria
POSTGRES_PASSWORD=ariapass123
POSTGRES_DB=aria_db
